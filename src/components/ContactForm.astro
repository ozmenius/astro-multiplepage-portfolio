---
// Contact form wired to Web3Forms (no backend needed). The access key is read
// from PUBLIC_WEB3FORMS_KEY and forwards submissions to the address bound to
// that key (contact@dennisozmen.com). On success it pushes a `contact_form_submit`
// event to the dataLayer for GTM → GA4.
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "";
---

<form id="contact-form" class="flex flex-col gap-4" novalidate>
  <input type="hidden" name="access_key" value={accessKey} />
  <input
    type="hidden"
    name="subject"
    value="New contact request — dennisozmen.com"
  />
  <input type="hidden" name="from_name" value="dennisozmen.com" />
  {/* Honeypot — bots fill this, humans never see it */}
  <input
    type="checkbox"
    name="botcheck"
    class="hidden"
    style="display:none"
    tabindex="-1"
    autocomplete="off"
  />

  <div class="flex flex-col gap-1.5">
    <label
      for="cf-name"
      class="text-sm font-medium text-neutral-700 dark:text-neutral-300"
    >
      Name
    </label>
    <input
      id="cf-name"
      type="text"
      name="name"
      required
      autocomplete="name"
      class="rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white/70 dark:bg-neutral-800/50 px-3 py-2 text-sm text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-indigo-500"
      placeholder="Your name"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label
      for="cf-email"
      class="text-sm font-medium text-neutral-700 dark:text-neutral-300"
    >
      Email
    </label>
    <input
      id="cf-email"
      type="email"
      name="email"
      required
      autocomplete="email"
      class="rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white/70 dark:bg-neutral-800/50 px-3 py-2 text-sm text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-indigo-500"
      placeholder="you@company.com"
    />
  </div>

  <div class="flex flex-col gap-1.5">
    <label
      for="cf-message"
      class="text-sm font-medium text-neutral-700 dark:text-neutral-300"
    >
      Message
    </label>
    <textarea
      id="cf-message"
      name="message"
      required
      rows="5"
      class="rounded-lg border border-neutral-300 dark:border-neutral-600 bg-white/70 dark:bg-neutral-800/50 px-3 py-2 text-sm text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-indigo-500"
      placeholder="How can I help?"></textarea>
  </div>

  <button
    type="submit"
    id="cf-submit"
    class="group inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-medium text-white bg-neutral-900 rounded-lg hover:bg-neutral-800 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-200 transition-all duration-300 disabled:opacity-60 disabled:cursor-not-allowed"
  >
    Send message
  </button>

  <p
    id="cf-status"
    role="status"
    aria-live="polite"
    class="text-sm text-neutral-600 dark:text-neutral-400 min-h-[1.25rem]"
  >
  </p>
</form>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const statusEl = document.getElementById("cf-status");
  const submitBtn = document.getElementById("cf-submit") as HTMLButtonElement | null;
  const FALLBACK = "Please try again later.";

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    if (statusEl) statusEl.textContent = "Sending…";
    if (submitBtn) submitBtn.disabled = true;

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });
      const result = await response.json();

      if (result.success) {
        if (statusEl)
          statusEl.textContent = "Thanks — your message has been sent.";
        form.reset();
        (window as any).dataLayer = (window as any).dataLayer || [];
        (window as any).dataLayer.push({
          event: "contact_form_submit",
          form_name: "contact",
          form_destination: "web3forms",
        });
      } else {
        if (statusEl)
          statusEl.textContent = `Something went wrong. ${FALLBACK}`;
        if (submitBtn) submitBtn.disabled = false;
      }
    } catch {
      if (statusEl) statusEl.textContent = `Network error. ${FALLBACK}`;
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
