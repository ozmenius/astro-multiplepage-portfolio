---
import { siteConfig } from "../config/content";
---

<!-- Footer Component -->
<section class="relative text-gray-700">
  <div
    class="container flex flex-col items-center justify-center min-h-[40px] mx-auto px-7 max-w-7xl sm:flex-row sm:min-h-[50px] bg-transparent py-4"
  >
    <a
      class="h-5 text-base group relative z-30 flex items-center space-x-1.5 text-neutral-700 dark:text-neutral-300 font-semibold"
      href="/"
    >
      <span
        class="text-xl -translate-y-0.5 group-hover:-rotate-12 group-hover:scale-[1.2] ease-in-out duration-300"
        >✦</span
      >
      <span class="-translate-y-0.5">Dennis Özmen</span>
    </a>
    <p
      class="mt-2 text-sm text-neutral-700 dark:text-neutral-300 sm:ml-4 sm:pl-4 sm:border-l sm:border-neutral-700 dark:sm:border-neutral-300 sm:mt-0"
    >
      © 2026 Dennis Özmen. All rights reserved.
    </p>
    <a
      href="/privacy/"
      class="mt-2 text-sm text-neutral-700 dark:text-neutral-300 underline hover:text-neutral-500 dark:hover:text-neutral-100 transition-colors sm:ml-4 sm:pl-4 sm:border-l sm:border-neutral-700 dark:sm:border-neutral-300 sm:mt-0"
    >
      Privacy
    </a>
    <button
      type="button"
      data-cc="show-preferencesModal"
      class="mt-2 text-sm text-neutral-700 dark:text-neutral-300 underline hover:text-neutral-500 dark:hover:text-neutral-100 transition-colors sm:ml-3 sm:mt-0"
    >
      Cookie settings
    </button>
    <span
      class="inline-flex justify-center mt-2 space-x-5 sm:ml-auto sm:mt-0 sm:justify-start"
    >
      <a
        href={siteConfig.social.linkedin}
        target="_blank"
        class="text-neutral-500 dark:text-neutral-400 hover:text-neutral-400 dark:hover:text-neutral-300"
      >
        <span class="sr-only">LinkedIn</span>
        <svg
          class="w-5 h-5"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
          ></path>
        </svg>
      </a>
      <a
        href={siteConfig.social.email}
        class="text-neutral-500 dark:text-neutral-400 hover:text-neutral-400 dark:hover:text-neutral-300"
      >
        <span class="sr-only">Email</span>
        <svg
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path>
        </svg>
      </a>
    </span>
  </div>
</section>
