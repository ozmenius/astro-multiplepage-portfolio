---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import JsonLd from "../components/JsonLd.astro";
import GoogleTagManager from "../components/GoogleTagManager.astro";
import ConsentMode from "../components/ConsentMode.astro";
import CookieConsent from "../components/CookieConsent.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  schema?: unknown;
  bodyClass?: string;
}

const { title, description, schema, bodyClass = "" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://dennisozmen.com");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {schema && <JsonLd schema={schema} />}
    <ConsentMode />
    <GoogleTagManager />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme") || "dark";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const initialTheme =
          savedTheme === "system"
            ? prefersDark
              ? "dark"
              : "light"
            : savedTheme;

        if (initialTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", (e) => {
            if (localStorage.getItem("theme") === "system") {
              if (e.matches) {
                document.documentElement.classList.add("dark");
              } else {
                document.documentElement.classList.remove("dark");
              }
            }
          });
      });
    </script>
    <slot name="head" />
  </head>
  <body
    class:list={[
      "bg-white dark:bg-neutral-900 transition-colors duration-300",
      bodyClass,
    ]}
  >
    <GoogleTagManager placement="body" />

    <div class="fixed inset-0 z-0 pointer-events-none">
      <div
        class="absolute inset-0 -z-10 dot-hexagon-light dark:dot-hexagon-dark"
      >
      </div>
      <div
        class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(255,255,255,0.5)_60%,rgba(255,255,255,0.9)_85%,white_100%)] dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(23,23,23,0.5)_60%,rgba(23,23,23,0.9)_85%,rgb(23,23,23)_100%)]"
      >
      </div>
      <div
        class="absolute left-1/2 top-0 -z-10 -translate-x-1/2 h-[1200px] w-[1200px] rounded-full bg-neutral-400 opacity-10 blur-[100px] dark:bg-neutral-600 dark:opacity-15"
        style="max-width: 100vw;"
      >
      </div>
    </div>

    <div class="relative z-10 flex min-h-screen flex-col">
      <Navigation />
      <main class="flex-1 flex flex-col">
        <slot />
      </main>
      <Footer />
    </div>
    <CookieConsent />
  </body>
</html>
