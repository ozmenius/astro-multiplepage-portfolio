---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import { getOrigin, contactSchema } from "../utils/schema.ts";

const origin = getOrigin(Astro.site);
---

<Layout
  title="Contact — Dennis Özmen"
  description="Get in touch about SEO, GEO, and digital marketing."
  schema={contactSchema(origin)}
>
  <section
    class="relative z-20 w-full max-w-xl mx-auto mt-16 sm:mt-24 mb-16 px-4 sm:px-6"
  >
    <h1
      class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-3xl lg:text-4xl"
    >
      Let's talk
    </h1>
    <p
      class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400 sm:text-base sm:leading-7"
    >
      Have a project in mind, or want to talk SEO, GEO, and marketing
      automation? Send a message and I'll get back to you.
    </p>

    <div class="mt-8">
      <ContactForm />
    </div>
  </section>
</Layout>
