---
import Layout from "../layouts/Layout.astro";
import { siteConfig, homeContent } from "../config/content.ts";
import { getOrigin, homeSchema } from "../utils/schema.ts";

const origin = getOrigin(Astro.site);
---

<Layout
  title={siteConfig.title}
  description={siteConfig.description}
  schema={homeSchema(origin)}
>
  <section
    class="flex-1 flex items-center justify-center py-10 lg:py-0"
  >
    <div
      class="flex flex-col-reverse lg:flex-row items-center justify-between w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 gap-8 lg:gap-12"
    >
      <div class="w-full lg:w-[45%] text-center lg:text-left">
        <h1
          class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-4xl"
        >
          {homeContent.title}
        </h1>
        <p
          class="mt-3 text-base sm:text-lg leading-7 text-neutral-600 dark:text-neutral-400"
        >
          {homeContent.description}
        </p>
        <div
          class="flex flex-col sm:flex-row gap-3 sm:gap-4 mt-5 justify-center lg:justify-start"
        >
          <a
            class="group inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-medium text-white bg-neutral-900 rounded-lg hover:bg-neutral-800 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-200 transition-all duration-300 hover:scale-105 cursor-pointer"
            href={homeContent.buttons.about.href}
            >{homeContent.buttons.about.text}<svg
              class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg
            ></a
          >
          <a
            class="group inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-medium text-neutral-900 bg-white border border-neutral-300 rounded-lg hover:bg-neutral-50 dark:bg-neutral-800 dark:text-neutral-100 dark:border-neutral-600 dark:hover:bg-neutral-700 transition-all duration-300 hover:scale-105 cursor-pointer"
            href={homeContent.buttons.posts.href}
            >{homeContent.buttons.posts.text}<svg
              class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg
            ></a
          >
        </div>
      </div>
      <div
        class="relative w-full lg:w-[45%] flex items-center justify-center bg-transparent z-20"
      >
        <div
          class="relative aspect-square w-full max-w-[280px] sm:max-w-[360px] lg:max-w-[420px] overflow-hidden rounded-2xl ring-1 ring-neutral-200 dark:ring-neutral-700 shadow-xl shadow-neutral-900/10 dark:shadow-black/40"
        >
          <img
            src={homeContent.image.src}
            alt={homeContent.image.alt}
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
