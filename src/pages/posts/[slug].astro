---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { getPostBySlug, getAllPostSlugs } from "../../utils/getPosts";
import { getOrigin, postSchema } from "../../utils/schema.ts";

// Map a frontmatter image path (public) to its src/assets counterpart so the
// hero is optimized (WebP + srcset). Falls back to the raw <img> if not found.
const heroImages = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/images/posts/*.{jpeg,jpg,png,webp}",
  { eager: true },
);
function resolveHero(path?: string): ImageMetadata | undefined {
  if (!path) return undefined;
  const file = path.split("/").pop();
  return Object.entries(heroImages).find(([k]) => k.endsWith("/" + file))?.[1]
    .default;
}

export async function getStaticPaths() {
  const slugs = getAllPostSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/posts/");
}

const post = getPostBySlug(slug);

if (!post) {
  return Astro.redirect("/posts/");
}

const { frontmatter, Content } = post;

if (!Content) {
  console.error(`Content component not found for slug: ${slug}`);
  return Astro.redirect("/posts/");
}

const heroImage = resolveHero(frontmatter.image);
const origin = getOrigin(Astro.site);
const postSchemaData = postSchema(origin, {
  title: frontmatter.title || "",
  description: frontmatter.description,
  date: frontmatter.date,
  image: frontmatter.image,
  slug,
  faq: frontmatter.faq,
});
---

<Layout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image}
  schema={postSchemaData}
>
  <article
    class="relative z-20 w-full max-w-4xl mx-auto mt-16 sm:mt-24 mb-12 px-4 sm:px-7 lg:px-0"
  >
    <a
      href="/posts/"
      class="inline-flex items-center gap-1.5 text-sm text-neutral-500 hover:text-neutral-700 dark:text-neutral-400 dark:hover:text-neutral-200 transition-colors"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M11 17l-5-5m0 0l5-5m-5 5h12"></path>
      </svg>
      All posts
    </a>

    <header class="mt-6 text-center">
      <h1
        class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-3xl lg:text-4xl mb-1.5"
      >
        {frontmatter.title}
      </h1>
      <div
        class="flex items-center justify-center gap-4 text-sm text-neutral-600 dark:text-neutral-400 mb-1.5"
      >
        <time datetime={frontmatter.date || ""}>
          {
            frontmatter.date
              ? new Date(frontmatter.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })
              : ""
          }
        </time>
        <span>•</span>
        <span>{frontmatter.readTime}</span>
        <span>•</span>
        <a
          href="/about/"
          class="hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
        >Dennis Özmen</a>
      </div>
    </header>

    {
      frontmatter.description && (
        <p class="text-lg text-neutral-600 dark:text-neutral-400 mb-8 text-center">
          {frontmatter.description}
        </p>
      )
    }

    {
      heroImage ? (
        <Image
          src={heroImage}
          alt={frontmatter.title}
          widths={[480, 800, 1200, 1600]}
          sizes="(min-width: 896px) 896px, 100vw"
          format="webp"
          quality={80}
          loading="eager"
          fetchpriority="high"
          class="w-full rounded-xl mb-12 object-cover max-h-[480px]"
        />
      ) : (
        frontmatter.image && (
          <img
            src={frontmatter.image}
            alt={frontmatter.title}
            class="w-full rounded-xl mb-12 object-cover max-h-[480px]"
          />
        )
      )
    }

    <div class="prose prose-neutral dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>
</Layout>
