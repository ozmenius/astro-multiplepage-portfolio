# Copy to .env for local dev, and set the same vars in Vercel (Project → Settings → Environment Variables).
# Both are PUBLIC_ (exposed to the browser) — that is expected for GTM and Web3Forms.

# Google Tag Manager container ID — enables GTM (which forwards to GA4). Format: GTM-XXXXXXX
PUBLIC_GTM_ID=

# Web3Forms access key — get one at https://web3forms.com (bind it to contact@dennisozmen.com)
PUBLIC_WEB3FORMS_KEY=
